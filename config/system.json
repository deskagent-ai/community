{
  "name": "DeskAgent - Your Desktop. Your Agent.",
  "context": "",
  "language": "de",
  "server_port": 8765,
  "console_logging": false,
  "developer_mode": false,
  "global_ai_override": null,
  "content_mode": "demo",
  "clear_temp_on_start": true,
  "ui": {
